{
  "name": "react-hono",
  "scripts": {
    "server": "bun run --hot server/src/index.ts",
    "client": "cd client && bun run --hot dev",
    "dev": "concurrently \"bun run server\" \"bun run client\"",
    "db:up": "docker-compose up -d",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.23",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.20.0",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "drizzle-seed": "^0.3.1"
  }
}